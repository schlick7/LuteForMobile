#!/bin/bash

# NewRelease Script for LuteForMobile
# Builds Android APK and PWA releases

set -e

# Project Folder
cd ~/LuteForMobile/

# Get current version
CURRENT_VERSION=$(grep "^version:" pubspec.yaml | awk '{print $2}')
CURRENT_DISPLAY_VERSION=$(echo "$CURRENT_VERSION" | cut -d'+' -f1)
CURRENT_BUILD_NUMBER=$(echo "$CURRENT_VERSION" | cut -d'+' -f2)

echo "=========================================="
echo "Current Version: $CURRENT_DISPLAY_VERSION (Build $CURRENT_BUILD_NUMBER)"
echo "=========================================="

# Ask for new version
read -p "Enter new version (e.g., 0.8.3): " NEW_VERSION

if [ -z "$NEW_VERSION" ]; then
    echo "✗ Version cannot be empty"
    exit 1
fi

# Ask for new build number
read -p "Enter new build number (default: $((CURRENT_BUILD_NUMBER + 1))): " NEW_BUILD_NUMBER

if [ -z "$NEW_BUILD_NUMBER" ]; then
    NEW_BUILD_NUMBER=$((CURRENT_BUILD_NUMBER + 1))
fi

FULL_VERSION="$NEW_VERSION+$NEW_BUILD_NUMBER"

echo "=========================================="
echo "Creating Release $NEW_VERSION (Build $NEW_BUILD_NUMBER)"
echo "=========================================="

# Update Version
sed -i "s/^version: .*/version: $FULL_VERSION/" pubspec.yaml
echo "✓ Updated pubspec.yaml to version $FULL_VERSION"

# Clean Build
flutter clean
echo "✓ Cleaned build"

# Get dependencies
flutter pub get
echo "✓ Retrieved dependencies"

# Build Android APK
echo "Building Android APK..."
flutter build apk --release
APK_PATH="build/app/outputs/flutter-apk/app-release.apk"
if [ -f "$APK_PATH" ]; then
    APK_NAME="LuteForMobile-v$NEW_VERSION.apk"
    mv "$APK_PATH" "$APK_NAME"
    echo "✓ Built and moved Android APK: $APK_NAME"
else
    echo "✗ APK build failed"
    exit 1
fi

# Build PWA
echo "=========================================="
echo "Building PWA..."
echo "=========================================="

# Build the web app first
flutter build web
echo "✓ Built web app"

# Add script
cp setup_pwa.py build/web/
echo "✓ Copied setup_pwa.py"

# Fix permissions
sudo find build/web -type f -exec chmod 644 {} \;
sudo find build/web -type d -exec chmod 755 {} \;
sudo chown -R $USER:$USER build/web
echo "✓ Fixed permissions"

# Create the zip
cd build/web
sudo zip -r ../../LuteForMobilePWA.zip * -x "*.last_build_id"
cd ../..
PWA_ZIP_NAME="LuteForMobilePWA-v$NEW_VERSION.zip"
mv LuteForMobilePWA.zip "$PWA_ZIP_NAME"
echo "✓ Created PWA zip: $PWA_ZIP_NAME"

echo "=========================================="
echo "Release Complete!"
echo "=========================================="
echo "Files created:"
echo "  - $APK_NAME"
echo "  - $PWA_ZIP_NAME"
echo ""
echo "Version: $NEW_VERSION (Build $NEW_BUILD_NUMBER)"
echo ""
echo "Don't forget to commit the version bump to git!"
